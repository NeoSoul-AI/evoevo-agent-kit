# Replace /ABSOLUTE/PATH/TO/evoevo-agent-kit/agent-client if you run from outside the agent-client directory.
EVOEVO_API_BASE_URL=https://api.example.com
EVOEVO_AGENT_API_KEY=oclk_replace_me
EVOEVO_POLL_SECONDS=60
EVOEVO_AUTO_CONFIRM_REQUEST=auto_if_allowed
EVOEVO_EXPLICIT_CONFIRM_AFTER_CREATE=false
EVOEVO_STRATEGY_COMMAND=python3 /ABSOLUTE/PATH/TO/evoevo-agent-kit/agent-client/scripts/example_strategy.py
EVOEVO_CLIENT_NAME=evoevo-agent-client
EVOEVO_CLIENT_VERSION=0.1.0

OPENAI_COMPAT_BASE_URL=http://127.0.0.1:11434
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=qwen2.5:14b
OPENAI_COMPAT_PATH=/v1/chat/completions
OPENAI_COMPAT_TIMEOUT_SECONDS=60
OPENAI_COMPAT_TEMPERATURE=0.2
OPENAI_COMPAT_MAX_TOKENS=700
OPENAI_COMPAT_SYSTEM_PROMPT_FILE=/ABSOLUTE/PATH/TO/evoevo-agent-kit/agent-client/assets/openai_compatible_system_prompt.md

HTTP_JSON_STRATEGY_URL=http://127.0.0.1:9000/infer
HTTP_JSON_STRATEGY_METHOD=POST
HTTP_JSON_STRATEGY_TIMEOUT_SECONDS=60
HTTP_JSON_STRATEGY_HEADERS_JSON={}
HTTP_JSON_STRATEGY_BEARER_TOKEN=
HTTP_JSON_STRATEGY_TEMPLATE_FILE=/ABSOLUTE/PATH/TO/evoevo-agent-kit/agent-client/assets/http_json_request_template.example.json
HTTP_JSON_STRATEGY_PROMPT_FILE=/ABSOLUTE/PATH/TO/evoevo-agent-kit/agent-client/assets/http_json_prompt_template.example.txt
HTTP_JSON_STRATEGY_RESPONSE_PATH=
